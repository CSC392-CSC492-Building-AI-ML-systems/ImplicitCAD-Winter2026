#!/bin/bash
# icad — Simple wrapper to run ImplicitCAD commands via Docker
#
# Usage:
#   ./icad compile input.scad -o output.stl
#   ./icad compile input.scad                   (outputs to input.stl)
#   ./icad run input.scad                       (compile and preview info)
#   echo 'sphere(r=10);' | ./icad compile -     (pipe code via stdin)
#
# This runs extopenscad inside the Docker container so you don't need
# to install Haskell/GHC/Cabal on your machine.

set -e

CONTAINER="implicitcad-engine"
CMD="${1:-help}"

if ! docker ps --format '{{.Names}}' | grep -q "^${CONTAINER}$"; then
  echo "Error: ImplicitCAD container not running."
  echo "Start it with: docker compose up -d"
  exit 1
fi

case "$CMD" in
  compile)
    shift
    INPUT="$1"
    if [ "$INPUT" = "-" ] || [ -z "$INPUT" ]; then
      # Read from stdin
      TMPFILE=$(mktemp /tmp/icad_XXXXXX.scad)
      cat > "$TMPFILE"
      docker cp "$TMPFILE" "$CONTAINER:/tmp/stdin.scad"
      docker exec "$CONTAINER" extopenscad -r 2 --fopenscad-compat /tmp/stdin.scad -o /tmp/output.stl
      if [ -n "$2" ] && [ "$2" = "-o" ] && [ -n "$3" ]; then
        docker cp "$CONTAINER:/tmp/output.stl" "$3"
        echo "Output: $3"
      else
        docker cp "$CONTAINER:/tmp/output.stl" "./output.stl"
        echo "Output: ./output.stl"
      fi
      rm -f "$TMPFILE"
    else
      OUTPUT="${INPUT%.scad}.stl"
      shift
      while [ $# -gt 0 ]; do
        case "$1" in
          -o) OUTPUT="$2"; shift 2 ;;
          *) shift ;;
        esac
      done
      docker cp "$INPUT" "$CONTAINER:/tmp/input.scad"
      docker exec "$CONTAINER" extopenscad -r 2 --fopenscad-compat /tmp/input.scad -o /tmp/output.stl
      docker cp "$CONTAINER:/tmp/output.stl" "$OUTPUT"
      echo "Output: $OUTPUT"
    fi
    ;;

  run)
    shift
    INPUT="$1"
    if [ -z "$INPUT" ]; then echo "Usage: icad run <file.scad>"; exit 1; fi
    docker cp "$INPUT" "$CONTAINER:/tmp/input.scad"
    docker exec "$CONTAINER" extopenscad -r 2 --fopenscad-compat /tmp/input.scad -o /tmp/output.stl
    echo "Compiled successfully."
    docker exec "$CONTAINER" ls -la /tmp/output.stl
    ;;

  version)
    docker exec "$CONTAINER" extopenscad --help 2>&1 | head -5
    ;;

  *)
    echo "ImplicitCAD CLI (via Docker)"
    echo ""
    echo "Usage:"
    echo "  ./icad compile input.scad [-o output.stl]"
    echo "  ./icad compile - [-o output.stl]          (read from stdin)"
    echo "  ./icad run input.scad                     (compile and show info)"
    echo "  ./icad version                            (show version)"
    echo ""
    echo "The Docker container '${CONTAINER}' must be running."
    echo "Start with: docker compose up -d"
    ;;
esac
