# ImplicitCAD Studio — Environment Configuration
# Copy this file to .env and adjust as needed.
# Docker Compose and studio.sh both read from .env automatically.

# ── Server ────────────────────────────────────────────────────────────────────
# Host port for the API server. Default 14000 avoids Windows reserved ports.
SERVER_HOST_PORT=14000

# Seconds before a compilation times out (default: 60).
COMPILE_TIMEOUT=60

# ── AI Providers ──────────────────────────────────────────────────────────────
# Which provider to use by default: ollama | openai | anthropic
ACTIVE_PROVIDER=ollama

# Model name (leave empty for auto-detect from the selected provider).
ACTIVE_MODEL=

# Ollama URL. Docker Desktop (macOS/Windows) resolves host.docker.internal automatically.
# On Linux without Docker Desktop, use your docker0 bridge IP instead (e.g., 172.17.0.1).
# Find it with: ip -4 addr show docker0 | grep inet
#           or: docker network inspect bridge -f '{{range .IPAM.Config}}{{.Gateway}}{{end}}'
# Ollama must also listen on all interfaces: OLLAMA_HOST=0.0.0.0 (see README troubleshooting).
OLLAMA_URL=http://host.docker.internal:11434

# API keys for cloud providers (optional — can also be set in the UI).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Workspace ─────────────────────────────────────────────────────────────────
# Host directory mounted into the server container as /workspace.
WORKSPACE_DIR=./_workspace

# ── Frontend Dev Server ───────────────────────────────────────────────────────
# Override proxy targets for the Vite dev server (npm run dev).
# Default matches the server port from docker-compose.yml.
# VITE_API_URL=http://localhost:14000

# ── Debug ─────────────────────────────────────────────────────────────────────
# Set to 1 to log raw LLM streaming tokens to the server console.
DEBUG_LLM_STREAM=0

# Set to 1 to disable chat history / thread context.
DISABLE_THREAD_CONTEXT=0
